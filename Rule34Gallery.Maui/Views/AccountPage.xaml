<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Rule34Gallery.Maui.ViewModels"
             xmlns:controls="clr-namespace:Rule34Gallery.Maui.Controls"
             x:Class="Rule34Gallery.Maui.Views.AccountPage"
             x:DataType="vm:AccountViewModel"
             Title="Account"
             BackgroundColor="#0D0D0D">
    <Grid>
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label Text="{Binding Status}" TextColor="#a0e070" />
            <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" TextColor="White" />
            <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" TextColor="White" />
            <Button Text="Sign in" Command="{Binding SignInCommand}" />
            <Button Text="Sign up" Command="{Binding SignUpCommand}" />
            <Button Text="Google sign-in" Command="{Binding SignInGoogleCommand}" IsVisible="{Binding IsGoogleAvailable}" />
            <Button Text="Sign out" Command="{Binding SignOutCommand}" IsVisible="{Binding IsSignedIn}" />
            <Label Text="Cloud sync" TextColor="#a0e070" FontAttributes="Bold" Margin="0,16,0,0" />
            <Label Text="{Binding CloudSyncStatus}" TextColor="#888" FontSize="12" />
            <Button Text="Sync now"
                    Command="{Binding SyncCloudCommand}"
                    IsEnabled="{Binding CanSyncCloud}"
                    BackgroundColor="#2a3a2a"
                    TextColor="White" />
        </VerticalStackLayout>
        <controls:PageLoadingOverlay Kind="Account"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    IsBusy="{Binding IsBusy}"
                                    ZIndex="99" />
    </Grid>
</ContentPage>
