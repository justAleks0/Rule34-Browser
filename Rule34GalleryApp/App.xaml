<Application x:Class="Rule34GalleryApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Rule34GalleryApp"
             xmlns:conv="clr-namespace:Rule34GalleryApp.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Themes/Rule34Theme.xaml" />
                <ResourceDictionary Source="Themes/TitleBarChrome.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="SystemAccentColor">#A0E060</Color>
            <Color x:Key="SystemAccentColorPrimary">#A0E060</Color>
            <Color x:Key="SystemAccentColorSecondary">#6B9E3A</Color>

            <!-- Brighter text on dark surfaces (WPF UI + pages) -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#B8B8B8"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#8A8A8A"/>
            <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#0D0D0D"/>

            <local:UrlToImageConverter x:Key="UrlToImage"/>
            <conv:RatingBrushConverter x:Key="RatingBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
