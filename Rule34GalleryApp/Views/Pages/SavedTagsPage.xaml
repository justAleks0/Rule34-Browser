<Page x:Class="Rule34GalleryApp.Views.Pages.SavedTagsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"
      Title="Tag sets"
      Background="{StaticResource BgBrush}">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitleText}"
                   Text="Tag sets"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Style="{StaticResource BrowseSectionHint}"
                   Text="Author tag sets here — apply, edit, delete, and sync to Android Lite."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="SaveCurrentButton"
                    Content="Save current search"
                    Style="{StaticResource PrimaryButton}"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="SaveCurrentButton_OnClick"/>
            <Button x:Name="SyncCloudButton"
                    Content="Sync from cloud"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8"
                    Click="SyncCloudButton_OnClick"/>
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Style="{StaticResource BodyText}"
                   Foreground="{StaticResource MutedBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <ListView x:Name="PresetsList"
                  Grid.Row="4"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectionChanged="PresetsList_OnSelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceRaisedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            Padding="12"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding TagsDisplay}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Apply"
                                        Tag="{Binding}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,6"
                                        Margin="0,0,6,0"
                                        Click="ApplyButton_OnClick"/>
                                <Button Content="Edit"
                                        Tag="{Binding}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6"
                                        Margin="0,0,6,0"
                                        Click="EditButton_OnClick"/>
                                <Button Content="Delete"
                                        Tag="{Binding}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,6"
                                        Click="DeleteButton_OnClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <controls:PageLoadingOverlay x:Name="LoadingOverlay"
                                    Kind="SavedTags"
                                    Grid.RowSpan="5"
                                    Panel.ZIndex="50"/>
    </Grid>
</Page>
