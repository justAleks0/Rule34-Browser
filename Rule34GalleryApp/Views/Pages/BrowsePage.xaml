<Page x:Class="Rule34GalleryApp.Views.Pages.BrowsePage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"

      Title="Browse"

      Background="{StaticResource BgBrush}"

      VerticalAlignment="Stretch"

      HorizontalAlignment="Stretch">

    <Grid x:Name="BrowseRoot" Margin="16,12,16,12">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource PageTitleText}"
                       Text="Browse"
                       Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource BrowseSectionHint}"
                       Text="Full search — filters, presets, query preview, grid &amp; feed."
                       TextWrapping="Wrap"/>
        </StackPanel>



        <WrapPanel Grid.Row="1" Margin="0,0,0,6">

            <Button Content="Search"

                    Style="{StaticResource PrimaryButton}"

                    MinWidth="96"

                    Padding="18,8"

                    Margin="0,0,8,0"

                    Click="SearchButton_OnClick"/>

            <Button Content="Previous page"

                    Style="{StaticResource SecondaryButton}"

                    MinWidth="108"

                    Margin="0,0,8,0"

                    Click="PrevButton_OnClick"/>

            <Button Content="Next page"

                    Style="{StaticResource SecondaryButton}"

                    MinWidth="96"

                    Margin="0,0,8,0"

                    Click="NextButton_OnClick"/>

            <Button x:Name="NavBackButton"

                    Content="History back"

                    Style="{StaticResource SecondaryButton}"

                    MinWidth="96"

                    Margin="0,0,8,0"

                    Click="NavBackButton_OnClick"/>

            <Button x:Name="NavForwardButton"

                    Content="History forward"

                    Style="{StaticResource SecondaryButton}"

                    MinWidth="108"

                    Margin="0,0,8,0"

                    Click="NavForwardButton_OnClick"/>

            <Button x:Name="FiltersButton"

                    Content="Filter results…"

                    Style="{StaticResource SecondaryButton}"

                    MinWidth="120"

                    Click="FiltersButton_OnClick"/>

            <StackPanel x:Name="RemoteFeedHint"

                        Orientation="Horizontal"

                        Margin="8,0,0,0">

                <Button x:Name="GridLayoutButton"

                        Content="Grid"

                        Style="{StaticResource SecondaryButton}"

                        MinWidth="56"

                        Margin="0,0,6,0"

                        Click="GridLayoutButton_OnClick"/>

                <Button x:Name="FeedLayoutButton"

                        Content="Feed"

                        Style="{StaticResource SecondaryButton}"

                        MinWidth="56"

                        ToolTip="Vertical feed — swipe through posts one at a time"

                        Click="FeedLayoutButton_OnClick"/>

            </StackPanel>

        </WrapPanel>



        <Expander x:Name="SearchExpander"

                  Grid.Row="2"

                  Style="{StaticResource R34Expander}"

                  IsExpanded="False"

                  Margin="0,0,0,6">

            <Expander.Header>

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Search &amp; filters"

                               Foreground="{StaticResource R34GreenBrush}"

                               FontSize="13"

                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="SearchExpanderSummary"

                               Foreground="{StaticResource MutedBrush}"

                               FontSize="11"

                               Margin="10,2,0,0"

                               Text="Click to expand"/>

                </StackPanel>

            </Expander.Header>

        <Border Background="{StaticResource SurfaceRaisedBrush}"

                BorderBrush="{StaticResource BorderBrush}"

                BorderThickness="1"

                CornerRadius="{StaticResource ControlCornerRadius}"

                Padding="14,12">

            <StackPanel>



                <!-- Search for -->

                <TextBlock Text="Search for"

                           Foreground="{StaticResource TextBrush}"

                           FontSize="14"

                           FontWeight="SemiBold"/>

                <TextBlock Text="Everything must match (AND): manual tags, plus every tag in each active search preset."

                           Foreground="{StaticResource MutedBrush}"

                           FontSize="12"

                           TextWrapping="Wrap"

                           Margin="0,2,0,8"/>

                <StackPanel Margin="0,0,0,8">

                    <Button x:Name="DescribeSearchButton"

                            Content="Describe search…"

                            Style="{StaticResource SecondaryButton}"

                            MinWidth="130"

                            HorizontalAlignment="Left"

                            Margin="0,0,0,6"

                            Click="DescribeSearchButton_OnClick"/>

                    <TextBlock Text="Describe search uses your OpenAI key (Account tab) to suggest tags. Optional — Browse and downloads do not need it."

                               Foreground="{StaticResource SubtleBrush}"

                               FontSize="12"

                               TextWrapping="Wrap"/>

                </StackPanel>

                <WrapPanel x:Name="SearchPresetsPanel" Margin="0,0,0,6"/>

                <WrapPanel x:Name="IncludeTagsPanel" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"/>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">

                        <Button x:Name="SearchPresetsButton"

                                Content="Search presets…"

                                Style="{StaticResource SecondaryButton}"

                                MinWidth="120"

                                Click="SearchPresetsButton_OnClick"/>

                        <Button x:Name="SaveTagsButton"

                                Content="Save tags…"

                                Style="{StaticResource SecondaryButton}"

                                MinWidth="120"

                                Margin="0,6,0,0"

                                ToolTip="Save current search tags as a preset (shown at top of Search presets)"

                                Click="SaveTagsButton_OnClick"/>

                    </StackPanel>

                    <TextBox x:Name="TagInput"

                             Grid.Column="1"

                             Style="{StaticResource R34FieldTextBox}"

                             Margin="0,0,8,0"

                             ToolTip="Extra tags (AND). Example: pokemon — press Enter to search"

                             TextChanged="TagInput_OnTextChanged"

                             KeyDown="TagInput_OnKeyDown"/>

                    <Button Grid.Column="2"

                            Content="Add tag"

                            Style="{StaticResource SecondaryButton}"

                            MinWidth="80"

                            Click="AddTagButton_OnClick"/>

                </Grid>



                <!-- Never show -->

                <TextBlock Text="Never show"

                           Foreground="{StaticResource TextBrush}"

                           FontSize="14"

                           FontWeight="SemiBold"/>

                <TextBlock Text="Extra -tags for this search only. For tags you never want anywhere (e.g. pokemon), use Settings → Always hidden."

                           Foreground="{StaticResource MutedBrush}"

                           FontSize="12"

                           TextWrapping="Wrap"

                           Margin="0,2,0,8"/>

                <WrapPanel x:Name="BlacklistTagsPanel" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"/>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <Button x:Name="PresetsButton"

                            Grid.Column="0"

                            Content="Topic presets…"

                            Style="{StaticResource SecondaryButton}"

                            MinWidth="120"

                            Margin="0,0,8,0"

                            Click="PresetsButton_OnClick"/>

                    <TextBox x:Name="BlacklistInput"

                             Grid.Column="1"

                             Style="{StaticResource R34FieldTextBox}"

                             Margin="0,0,8,0"

                             ToolTip="Type to search tags — same autocomplete as Search for"

                             TextChanged="BlacklistInput_OnTextChanged"

                             KeyDown="BlacklistInput_OnKeyDown"/>

                    <Button Grid.Column="2"

                            Content="Add exclude"

                            Style="{StaticResource SecondaryButton}"

                            MinWidth="96"

                            Click="ExcludeTagButton_OnClick"/>

                </Grid>



                <TextBlock Margin="0,0,0,0"

                           Foreground="{StaticResource SubtleBrush}"

                           FontSize="11"

                           Text="API query"/>

                <TextBlock x:Name="QueryPreviewText"

                           Foreground="{StaticResource MutedBrush}"

                           FontSize="11"

                           FontFamily="Consolas, Courier New"

                           TextWrapping="Wrap"

                           Margin="0,2,0,0"/>



            </StackPanel>

        </Border>

        </Expander>



        <!-- Autocomplete -->

        <Popup x:Name="AutocompletePopup"

               PlacementTarget="{Binding ElementName=TagInput}"

               Placement="Bottom"

               StaysOpen="False"

               AllowsTransparency="True">

            <Border Background="{StaticResource SurfaceRaisedBrush}"

                    BorderBrush="{StaticResource BorderBrush}"

                    BorderThickness="1"

                    CornerRadius="8"

                    MinWidth="{Binding ActualWidth, ElementName=TagInput}"

                    MaxHeight="220">

                <ListBox x:Name="AutocompleteList"

                         BorderThickness="0"

                         Background="Transparent"

                         SelectionChanged="AutocompleteList_OnSelectionChanged">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <controls:TagChip TagText="{Binding Value}" Category="{Binding Category}"/>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </Border>

        </Popup>



        <!-- Exclude tag autocomplete -->

        <Popup x:Name="BlacklistAutocompletePopup"

               PlacementTarget="{Binding ElementName=BlacklistInput}"

               Placement="Bottom"

               StaysOpen="False"

               AllowsTransparency="True">

            <Border Background="{StaticResource SurfaceRaisedBrush}"

                    BorderBrush="{StaticResource BorderBrush}"

                    BorderThickness="1"

                    CornerRadius="8"

                    MinWidth="{Binding ActualWidth, ElementName=BlacklistInput}"

                    MaxHeight="220">

                <ListBox x:Name="BlacklistAutocompleteList"

                         BorderThickness="0"

                         Background="Transparent"

                         SelectionChanged="BlacklistAutocompleteList_OnSelectionChanged">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <controls:TagChip TagText="{Binding Value}" Category="{Binding Category}"/>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </Border>

        </Popup>



        <!-- Filters popup — every field labeled -->

        <Popup x:Name="FiltersPopup"

               PlacementTarget="{Binding ElementName=FiltersButton}"

               Placement="Bottom"

               StaysOpen="False"

               AllowsTransparency="True">

            <Border Background="{StaticResource SurfaceRaisedBrush}"

                    BorderBrush="{StaticResource BorderBrush}"

                    BorderThickness="1"

                    CornerRadius="8"

                    Padding="16,14"

                    MinWidth="400"

                    MaxWidth="460">

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="480">

                    <StackPanel>

                        <TextBlock Text="Filter results"

                                   Foreground="{StaticResource TextBrush}"

                                   FontWeight="SemiBold"

                                   FontSize="14"

                                   Margin="0,0,0,12"/>



                        <TextBlock Text="Allowed ratings"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">

                            <CheckBox x:Name="RatingSafeCheck"

                                      Style="{StaticResource R34CheckBox}"

                                      Content="Safe"

                                      Margin="0,0,16,0"

                                      Checked="SearchOption_OnChanged"

                                      Unchecked="SearchOption_OnChanged"/>

                            <CheckBox x:Name="RatingQuestionableCheck"

                                      Style="{StaticResource R34CheckBox}"

                                      Content="Questionable"

                                      Margin="0,0,16,0"

                                      Checked="SearchOption_OnChanged"

                                      Unchecked="SearchOption_OnChanged"/>

                            <CheckBox x:Name="RatingExplicitCheck"

                                      Style="{StaticResource R34CheckBox}"

                                      Content="Explicit"

                                      Checked="SearchOption_OnChanged"

                                      Unchecked="SearchOption_OnChanged"/>

                        </StackPanel>



                        <TextBlock Text="Media type"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <ComboBox x:Name="MediaFilterCombo"

                                  Style="{StaticResource R34ComboBox}"

                                  Margin="0,0,0,12"

                                  SelectionChanged="SearchOption_OnChanged">

                            <ComboBoxItem Content="All types"/>

                            <ComboBoxItem Content="Images only"/>

                            <ComboBoxItem Content="Videos only"/>

                            <ComboBoxItem Content="GIFs only"/>

                            <ComboBoxItem Content="Animated only"/>

                        </ComboBox>



                        <TextBlock Text="Sort order"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <ComboBox x:Name="SortModeCombo"

                                  Style="{StaticResource R34ComboBox}"

                                  Margin="0,0,0,12"

                                  SelectionChanged="SearchOption_OnChanged">

                            <ComboBoxItem Content="Highest score first"/>

                            <ComboBoxItem Content="Lowest score first"/>

                            <ComboBoxItem Content="Newest first"/>

                            <ComboBoxItem Content="Oldest first"/>

                            <ComboBoxItem Content="Random"/>

                        </ComboBox>



                        <TextBlock Text="Results per page"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <ComboBox x:Name="LimitCombo"

                                  Style="{StaticResource R34ComboBox}"

                                  Margin="0,0,0,14"

                                  SelectionChanged="LimitCombo_OnChanged">

                            <ComboBoxItem Content="25"/>

                            <ComboBoxItem Content="50"/>

                            <ComboBoxItem Content="100"/>

                            <ComboBoxItem Content="200"/>

                        </ComboBox>



                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">

                            <TextBlock Text="Block AI-generated art"

                                       Foreground="{StaticResource TextBrush}"

                                       FontSize="13"

                                       VerticalAlignment="Center"

                                       Margin="0,0,12,0"/>

                            <CheckBox x:Name="FilterAiCheckBox"

                                      Style="{StaticResource ToggleSwitchStyle}"

                                      VerticalAlignment="Center"

                                      Checked="FilterAi_OnChanged"

                                      Unchecked="FilterAi_OnChanged"/>

                        </StackPanel>



                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,12"/>



                        <TextBlock Text="Minimum score (leave empty for no limit)"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="MinScoreInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 Margin="0,0,0,10"

                                 LostFocus="SearchOption_OnChanged"

                                 KeyDown="NumericFilter_OnKeyDown"/>



                        <TextBlock Text="Minimum width in pixels"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="MinWidthInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 Margin="0,0,0,10"

                                 LostFocus="SearchOption_OnChanged"

                                 KeyDown="NumericFilter_OnKeyDown"/>



                        <TextBlock Text="Minimum height in pixels"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="MinHeightInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 Margin="0,0,0,14"

                                 LostFocus="SearchOption_OnChanged"

                                 KeyDown="NumericFilter_OnKeyDown"/>



                        <TextBlock Text="Artist tag"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="ArtistFilterInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 Margin="0,0,0,10"

                                 LostFocus="SearchOption_OnChanged"/>



                        <TextBlock Text="Character tag"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="CharacterFilterInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 Margin="0,0,0,10"

                                 LostFocus="SearchOption_OnChanged"/>



                        <TextBlock Text="Series / copyright tag"

                                   Foreground="{StaticResource MutedBrush}"

                                   FontSize="12"

                                   FontWeight="SemiBold"

                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="CopyrightFilterInput"

                                 Style="{StaticResource R34FieldTextBox}"

                                 LostFocus="SearchOption_OnChanged"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Popup>



        <TextBlock x:Name="StatusText"

                   Grid.Row="3"

                   Foreground="{StaticResource MutedBrush}"

                   FontSize="12"

                   Margin="0,0,0,6"

                   Text="Ready"/>



        <controls:GalleryGrid x:Name="Gallery"

                              Grid.Row="4"

                              VerticalAlignment="Stretch"

                              HorizontalAlignment="Stretch"

                              CardClicked="Gallery_OnCardClicked"

                              FavoriteClicked="Gallery_OnFavoriteClicked"

                              WatchLaterClicked="Gallery_OnWatchLaterClicked"

                              AddToListClicked="Gallery_OnAddToListClicked"
                              DownloadClicked="Gallery_OnDownloadClicked"/>

        <controls:BrowseFeedPanel x:Name="FeedPanel"

                                  Grid.Row="4"

                                  Visibility="Collapsed"/>



        <Border x:Name="BottomPagerPanel"

                Grid.Row="5"

                Background="{StaticResource SurfaceRaisedBrush}"

                BorderBrush="{StaticResource BorderBrush}"

                BorderThickness="1"

                CornerRadius="{StaticResource ControlCornerRadius}"

                Padding="12,10"

                Margin="0,8,0,0"

                Visibility="Collapsed">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Button x:Name="BottomPrevButton"

                        Grid.Column="0"

                        Content="← Previous page"

                        Style="{StaticResource SecondaryButton}"

                        HorizontalAlignment="Left"

                        MinWidth="120"

                        Click="PrevButton_OnClick"/>

                <TextBlock x:Name="BottomPageText"

                           Grid.Column="1"

                           VerticalAlignment="Center"

                           Foreground="{StaticResource MutedBrush}"

                           FontWeight="SemiBold"

                           Margin="16,0"/>

                <Button x:Name="BottomNextButton"

                        Grid.Column="2"

                        Content="Next page →"

                        Style="{StaticResource SecondaryButton}"

                        HorizontalAlignment="Right"

                        MinWidth="120"

                        Click="NextButton_OnClick"/>

            </Grid>

        </Border>

        <controls:PageLoadingOverlay x:Name="LoadingOverlay"
                                    Kind="Browse"
                                    Grid.RowSpan="6"
                                    Panel.ZIndex="50"/>

    </Grid>

</Page>

