<Page x:Class="Rule34GalleryApp.Views.Pages.SyncPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"
      xmlns:core="clr-namespace:Rule34Gallery.Core;assembly=Rule34Gallery.Core"
      xmlns:sync="clr-namespace:Rule34Gallery.Core.CloudSync;assembly=Rule34Gallery.Core"
      Title="Cloud sync"
      Background="{StaticResource BgBrush}"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch">
    <Grid>
        <ScrollViewer x:Name="SyncScroll"
                      VerticalAlignment="Stretch"
                      VerticalScrollBarVisibility="Visible"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly">
            <StackPanel Margin="20,16,20,24" MaxWidth="900">
                <TextBlock Style="{StaticResource PageTitleText}"
                           Text="Cloud sync"
                           Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Text="Sync control center — see what is on this device vs your account, then upload or download with merge or replace."/>

                <!-- Status banner -->
                <Border Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="14,12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock x:Name="SyncStatusHint"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <Border x:Name="StatusChip"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="StatusChipText"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="LastSyncText"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="StepsSummaryText"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="PreviewErrorText"
                                   Foreground="#c45c5c"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="UploadButton"
                            Content="Upload to cloud"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="UploadButton_OnClick"/>
                    <Button x:Name="DownloadButton"
                            Content="Download from cloud"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="DownloadButton_OnClick"/>
                    <Button x:Name="RefreshPreviewButton"
                            Content="Refresh preview"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="RefreshPreviewButton_OnClick"/>
                    <Button Content="Open Account"
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenAccountButton_OnClick"/>
                </StackPanel>

                <!-- Bulk selection helpers -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Select cloud-only"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Padding="10,4"
                            FontSize="11"
                            Click="SelectCloudOnly_OnClick"/>
                    <Button Content="Select local-only"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Padding="10,4"
                            FontSize="11"
                            Click="SelectLocalOnly_OnClick"/>
                    <Button Content="Delete cloud item"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4"
                            FontSize="11"
                            Click="DeleteCloudItem_OnClick"/>
                </StackPanel>

                <!-- Data explorer -->
                <Border Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="12"
                        Margin="0,0,0,12"
                        MinHeight="180">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Data explorer"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <TreeView x:Name="DataExplorer"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  SelectedItemChanged="DataExplorer_OnSelectedItemChanged">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"
                                                  Click="NodeCheckBox_Click">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Margin="8,0,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding CountsSummary}"/>
                                        <TextBlock Margin="8,0,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Status}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- What syncs -->
                <TextBlock Text="What syncs"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,8"/>
                <WrapPanel Margin="0,0,0,12">
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Width="200"
                            Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="API credentials" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12"/>
                            <TextBlock Text="Rule34, Danbooru, e621, OpenAI keys" Foreground="{StaticResource SubtleBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Width="200"
                            Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="Library" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12"/>
                            <TextBlock Text="Favorites, lists, watch later" Foreground="{StaticResource SubtleBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Width="200"
                            Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="Saved tag sets" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12"/>
                            <TextBlock Text="Named search presets" Foreground="{StaticResource SubtleBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Width="200"
                            Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="For You" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12"/>
                            <TextBlock Text="Topics, searches, activity" Foreground="{StaticResource SubtleBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Activity log -->
                <TextBlock Text="Activity log"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="14"
                        MinHeight="120">
                    <Grid>
                        <ItemsControl x:Name="StepsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type core:CloudSyncStep}">
                                    <Border Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,10"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding StatusText}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                                       Text="{Binding Detail}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                                       Text="{Binding ErrorMessage}"
                                                       Foreground="#c45c5c"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="EmptyStepsPanel"
                                   Text="No sync activity yet. Upload, download, or refresh preview."
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <controls:PageLoadingOverlay x:Name="LoadingOverlay"
                                    Kind="Sync"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Panel.ZIndex="50"/>
    </Grid>
</Page>
