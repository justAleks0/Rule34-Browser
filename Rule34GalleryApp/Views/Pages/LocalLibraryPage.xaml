<Page x:Class="Rule34GalleryApp.Views.Pages.LocalLibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"
      Title="Local libraries"
      Background="{StaticResource BgBrush}"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitleText}"
                   Text="Local libraries"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="10,8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Type"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,10,6"/>
                <WrapPanel x:Name="TopCategoryFilterPanel"
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Category"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <ComboBox x:Name="LeafCategoryCombo"
                          Grid.Row="1"
                          Grid.Column="1"
                          MinWidth="200"
                          MaxWidth="480"
                          HorizontalAlignment="Left"
                          SelectionChanged="LeafCategoryCombo_OnSelectionChanged"/>
            </Grid>
        </Border>

        <Expander x:Name="SetupExpander"
                  Grid.Row="2"
                  Style="{StaticResource R34Expander}"
                  IsExpanded="False"
                  Margin="0,0,0,8">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Library setup"
                               Foreground="{StaticResource R34GreenBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="SetupExpanderSummary"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Margin="10,2,0,0"
                               Text="Click to expand"/>
                </StackPanel>
            </Expander.Header>
            <Border Background="{StaticResource SurfaceRaisedBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="12,10"
                    Margin="0,4,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Library"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="LibraryCombo"
                                  Grid.Column="1"
                                  Margin="0,0,8,0"
                                  SelectionChanged="LibraryCombo_OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Content="New"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,6,0"
                                Padding="12,6"
                                Click="NewLibraryButton_OnClick"/>
                        <Button Grid.Column="3"
                                Content="Delete"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="False"
                                x:Name="DeleteLibraryButton"
                                Padding="12,6"
                                Click="DeleteLibraryButton_OnClick"/>
                    </Grid>

                    <StackPanel x:Name="LibraryDetailsPanel">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Name"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="LibraryNameInput"
                                     Grid.Column="1"
                                     Style="{StaticResource R34FieldTextBox}"
                                     LostFocus="LibraryNameInput_OnLostFocus"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Root folder"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="RootFolderInput"
                                     Grid.Column="1"
                                     Style="{StaticResource R34FieldTextBox}"
                                     Margin="0,0,6,0"
                                     ToolTip="Parent folder to scan (hidden paths OK — paste the full path)."
                                     LostFocus="RootFolderInput_OnLostFocus"/>
                            <Button Grid.Column="2"
                                    Content="Browse…"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Padding="10,6"
                                    Click="BrowseRootFolderButton_OnClick"/>
                            <Button Grid.Column="3"
                                    Content="Scan"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,6"
                                    ToolTip="Find nested folders that contain media."
                                    Click="ScanSubfoldersButton_OnClick"/>
                        </Grid>
                        <TextBlock x:Name="RootFolderStatus"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Margin="52,0,0,8"
                                   TextWrapping="Wrap"/>

                        <Expander x:Name="CategoriesExpander"
                                  Style="{StaticResource R34Expander}"
                                  IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Categories"
                                               Foreground="{StaticResource SubtleBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="CategoriesExpanderSummary"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               Margin="8,1,0,0"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,6,0,0">
                                <ScrollViewer MaxHeight="220"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="CategoriesList"/>
                                </ScrollViewer>
                                <Button Content="Add folder…"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        Padding="10,5"
                                        Click="AddCategoryButton_OnClick"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Expander>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12"
                   Margin="0,0,0,8"/>

        <controls:GalleryGrid x:Name="Gallery"
                              Grid.Row="4"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"/>
        <controls:PageLoadingOverlay x:Name="LoadingOverlay"
                                    Kind="LocalLibrary"
                                    Grid.RowSpan="5"
                                    Panel.ZIndex="50"/>
    </Grid>
</Page>
