<UserControl x:Class="Rule34GalleryApp.Views.Overlays.ImageViewerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Rule34GalleryApp"
             xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"
             Visibility="Collapsed">
    <UserControl.Resources>
        <Storyboard x:Key="ShowViewer">
            <DoubleAnimation Storyboard.TargetName="ViewerRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.22"/>
            <DoubleAnimation Storyboard.TargetName="ViewerScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.97" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ViewerScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.97" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    <Grid x:Name="ViewerRoot" Opacity="0" Background="#F0000000">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="ViewerScale" CenterX="0.5" CenterY="0.5" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>
        <Grid x:Name="ViewerContent" Margin="0,48,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#161616"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ViewerTitle" FontWeight="SemiBold" FontSize="15" Margin="0,0,16,0"/>
                    <TextBlock x:Name="ViewerMeta" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="ViewerToolbarButtons"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,8,0">
                    <Button x:Name="ViewerFavoriteButton"
                            Content="☆ Favorite"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerFavoriteButton_OnClick"/>
                    <Button x:Name="ViewerWatchLaterButton"
                            Content="○ Watch Later"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerWatchLaterButton_OnClick"/>
                    <Button x:Name="ViewerRefreshMetadataButton"
                            Content="↻ Metadata"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            ToolTip="Re-fetch tags and artist/series/character from Rule34 and update cloud save."
                            Click="ViewerRefreshMetadataButton_OnClick"/>
                    <Button x:Name="ViewerAddToListButton"
                            Content="+ Add to list"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerAddToListButton_OnClick"/>
                    <Button x:Name="ViewerDownloadButton"
                            Content="↓ Download"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerDownloadButton_OnClick"/>
                    <Button x:Name="ViewerThumbButton"
                            Content="Thumb"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerThumbButton_OnClick"/>
                    <Button x:Name="ShowTagsButton"
                            Content="Tags"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ToggleTagsButton_OnClick"/>
                    <Button x:Name="ZoomOutButton"
                            Content="−"
                            Style="{StaticResource SecondaryButton}"
                            Width="32"
                            Margin="0,0,4,0"
                            ToolTip="Zoom out (-)"
                            Click="ZoomOutButton_OnClick"/>
                    <TextBlock x:Name="ZoomLevelText"
                               Text="Fit"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               MinWidth="40"
                               TextAlignment="Center"
                               Margin="0,0,4,0"/>
                    <Button x:Name="ZoomInButton"
                            Content="+"
                            Style="{StaticResource SecondaryButton}"
                            Width="32"
                            Margin="0,0,4,0"
                            ToolTip="Zoom in (+)"
                            Click="ZoomInButton_OnClick"/>
                    <Button x:Name="ZoomFitButton"
                            Content="Fit"
                            Style="{StaticResource SecondaryButton}"
                            Width="36"
                            Margin="0,0,8,0"
                            ToolTip="Fit to window (0)"
                            Click="ZoomFitButton_OnClick"/>
                    <Button Content="Open in browser"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            Click="ViewerOpenInBrowser_OnClick"/>
                    <Button Content="Close"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,6"
                            Click="CloseButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="TagsColumn" Width="220"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="ViewerStage"
                  Grid.Column="0"
                  MouseMove="ViewerStage_OnMouseMove"
                  MouseLeave="ViewerStage_OnMouseLeave">
                <ScrollViewer x:Name="ImageScrollViewer"
                              Panel.ZIndex="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              CanContentScroll="False"
                              Margin="12,8"
                              Focusable="False"
                              PreviewMouseWheel="ImageScrollViewer_OnPreviewMouseWheel"
                              PreviewMouseLeftButtonDown="ImageScrollViewer_OnPanStart"
                              PreviewMouseMove="ImageScrollViewer_OnPanMove"
                              PreviewMouseLeftButtonUp="ImageScrollViewer_OnPanEnd"
                              MouseDoubleClick="ImageScrollViewer_OnDoubleClick"
                              Cursor="Arrow">
                    <Grid x:Name="ImageZoomHost" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image x:Name="ViewerImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </ScrollViewer>
                <MediaElement x:Name="ViewerMedia"
                              Panel.ZIndex="1"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              ScrubbingEnabled="True"
                              Stretch="Uniform"
                              Visibility="Collapsed"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="48,8"/>
                <TextBlock x:Name="ViewerLoadingText"
                           Panel.ZIndex="2"
                           Text="Loading..."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button x:Name="ViewerPrevButton"
                        Panel.ZIndex="12"
                        Content="‹"
                        FontSize="36"
                        Width="52"
                        Height="100"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        Opacity="0.9"
                        Click="ViewerPrevButton_OnClick"/>
                <Button x:Name="ViewerNextButton"
                        Panel.ZIndex="12"
                        Content="›"
                        FontSize="36"
                        Width="52"
                        Height="100"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        Opacity="0.9"
                        Click="ViewerNextButton_OnClick"/>

                <Border x:Name="PlaybackProgressHint"
                        Panel.ZIndex="29"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Height="4"
                        Margin="48,0,48,6"
                        Background="#30FFFFFF"
                        CornerRadius="2"
                        Visibility="Collapsed"
                        Cursor="Hand"
                        MouseEnter="PlaybackProgressHint_OnMouseEnter"
                        SizeChanged="PlaybackProgressHint_OnSizeChanged">
                    <Border x:Name="PlaybackProgressFill"
                            Background="#a0e070"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Width="0"/>
                </Border>

                <Border x:Name="PlaybackControlsPanel"
                        Panel.ZIndex="30"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Margin="48,0,48,8"
                        Background="#CC141414"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,6"
                        Visibility="Collapsed"
                        MouseEnter="PlaybackControlsPanel_OnMouseEnter"
                        MouseLeave="PlaybackControlsPanel_OnMouseLeave">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PlayPauseButton"
                                Grid.Column="0"
                                Content="&#xE768;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="36"
                                Height="28"
                                FontSize="14"
                                Padding="0"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"
                                ToolTip="Play / Pause (Space)"
                                Click="PlayPauseButton_OnClick"/>
                        <Slider x:Name="SeekSlider"
                                Grid.Column="1"
                                Style="{StaticResource R34SeekSlider}"
                                Minimum="0"
                                Maximum="1"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                IsMoveToPointEnabled="True"
                                ToolTip="Click or drag to seek"
                                PreviewMouseLeftButtonDown="SeekSlider_OnPreviewMouseDown"
                                ValueChanged="SeekSlider_OnValueChanged"/>
                        <TextBlock x:Name="PlaybackTimeText"
                                   Grid.Column="2"
                                   Text="0:00 / 0:00"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   MinWidth="76"/>
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    Margin="0,0,8,0">
                            <Button x:Name="MuteButton"
                                    Content="&#xE767;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="36"
                                    Height="28"
                                    FontSize="14"
                                    Padding="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    ToolTip="Mute (M)"
                                    Click="MuteButton_OnClick"/>
                            <Slider x:Name="VolumeSlider"
                                    Style="{StaticResource R34VolumeSlider}"
                                    Width="72"
                                    Minimum="0"
                                    Maximum="100"
                                    VerticalAlignment="Center"
                                    ValueChanged="VolumeSlider_OnValueChanged"/>
                        </StackPanel>
                        <CheckBox x:Name="LoopCheckBox"
                                  Grid.Column="4"
                                  Content="Loop"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  ToolTip="Loop playback (L)"
                                  Checked="LoopCheckBox_OnChanged"
                                  Unchecked="LoopCheckBox_OnChanged"/>
                        <ComboBox x:Name="SpeedCombo"
                                  Grid.Column="5"
                                  Width="64"
                                  ToolTip="Playback speed"
                                  SelectionChanged="SpeedCombo_OnSelectionChanged">
                            <ComboBoxItem Content="0.5×"/>
                            <ComboBoxItem Content="0.75×"/>
                            <ComboBoxItem Content="1×"/>
                            <ComboBoxItem Content="1.25×"/>
                            <ComboBoxItem Content="1.5×"/>
                            <ComboBoxItem Content="2×"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border x:Name="ViewerHintPanel"
                        Panel.ZIndex="10"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Background="#AA000000"
                        CornerRadius="6"
                        Padding="10,5"
                        Margin="0,0,0,16">
                    <TextBlock x:Name="ViewerHintText"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Text="Tag: search  ·  Shift+tag: always hide  ·  ← →  ·  Esc"/>
                </Border>
            </Grid>

            <Border x:Name="TagsSidebar"
                    Grid.Column="1"
                    Background="#141414"
                    BorderBrush="#333333"
                    BorderThickness="1,0,0,0"
                    Padding="10,8">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="Tags"
                                   Foreground="{StaticResource R34GreenBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="ToggleTagsButton"
                                Content="Hide"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right"
                                Padding="8,3"
                                FontSize="11"
                                Click="ToggleTagsButton_OnClick"/>
                    </Grid>
                    <ScrollViewer x:Name="ViewerTagsScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ViewerTagsPanel"/>
                    </ScrollViewer>
                    <TextBlock x:Name="ViewerTagsEmptyText"
                               DockPanel.Dock="Top"
                               Text="No tags."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Visibility="Collapsed"/>
                </DockPanel>
            </Border>
        </Grid>
        </Grid>

        <Grid x:Name="BrowserChoiceLayer"
              Visibility="Collapsed"
              Panel.ZIndex="300"
              Background="#CC000000"
              MouseDown="BrowserChoiceBackdrop_OnMouseDown">
            <Border Background="{StaticResource SurfaceRaisedBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MouseDown="BrowserChoicePanel_OnMouseDown">
                <StackPanel>
                    <TextBlock Text="Open in browser"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Choose how to open this post on rule34.xxx."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               Margin="0,0,0,16"/>
                    <Button Content="Normal tab"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,8"
                            Click="BrowserChoiceNormal_OnClick"/>
                    <Button Content="Private tab"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8"
                            ToolTip="Incognito / InPrivate / private window (Chrome, Edge, Firefox, Brave, Opera)"
                            Click="BrowserChoicePrivate_OnClick"/>
                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Click="BrowserChoiceCancel_OnClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
