<UserControl x:Class="Rule34GalleryApp.Views.Overlays.ForYouManageOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             Focusable="True"
             KeyDown="ForYouManageOverlay_OnKeyDown">
    <Grid Background="#CC000000"
          MouseDown="Backdrop_OnMouseDown">
        <Border Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24"
                Margin="40,28"
                MaxWidth="960"
                MinWidth="640"
                MinHeight="560"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                MouseDown="DialogPanel_OnMouseDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock x:Name="TitleText"
                               Text="Manage"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Close"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,8"
                            Click="CloseButton_OnClick"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock x:Name="HintText"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               Margin="0,0,0,10"/>
                    <Button x:Name="AddTopicButton"
                            Content="Add topic"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            MinWidth="120"
                            Padding="14,8"
                            Visibility="Collapsed"
                            Click="AddTopicButton_OnClick"/>
                    <Border x:Name="StrengthEditorPanel"
                            Visibility="Collapsed"
                            Background="{StaticResource BgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock x:Name="StrengthEditorTitle"
                                       Text="Add topic"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="StrengthTagLabel"
                                       Text="Tag name"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="StrengthTagBox"
                                     Style="{StaticResource R34FieldTextBox}"
                                     Margin="0,0,0,8"/>
                            <TextBlock x:Name="StrengthTopicName"
                                       Foreground="{StaticResource R34GreenBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="StrengthValueText"
                                       Text="Score: 80.0"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,4"/>
                            <Slider x:Name="StrengthSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="80"
                                    Margin="0,0,0,4"/>
                            <TextBlock Text="0 = weak · 100 = strongest"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="88"
                                        Padding="14,8"
                                        Margin="0,0,8,0"
                                        Click="StrengthSave_OnClick"/>
                                <Button Content="Cancel"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="88"
                                        Padding="14,8"
                                        Click="StrengthCancel_OnClick"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ListPanel"/>
                </ScrollViewer>

                <TextBlock Grid.Row="3"
                           x:Name="EmptyText"
                           Style="{StaticResource MutedText}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
