<UserControl x:Class="Rule34GalleryApp.Views.Overlays.TagDiscoverOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Rule34GalleryApp.Controls"
             Visibility="Collapsed"
             Focusable="True"
             KeyDown="TagDiscoverOverlay_OnKeyDown">
    <Grid Background="#CC000000"
          MouseDown="Backdrop_OnMouseDown">
        <Border Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                MaxWidth="580"
                Width="580"
                MaxHeight="680"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MouseDown="DialogPanel_OnMouseDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: title + mode -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Describe what you want"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <RadioButton x:Name="ThemeModeRadio"
                                     Content="By theme"
                                     GroupName="DiscoverMode"
                                     IsChecked="True"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     Margin="0,0,12,0"
                                     Checked="DiscoverModeRadio_OnChecked"/>
                        <RadioButton x:Name="QuestionnaireModeRadio"
                                     Content="Questionnaire"
                                     GroupName="DiscoverMode"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     Margin="0,0,12,0"
                                     Checked="DiscoverModeRadio_OnChecked"/>
                        <RadioButton x:Name="ConceptLookupModeRadio"
                                     Content="Find tag name"
                                     GroupName="DiscoverMode"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     ToolTip="Slang or vague wording → the real Rule34 tag (e.g. gyaru), not a literal copy of your words"
                                     Margin="0,0,12,0"
                                     Checked="DiscoverModeRadio_OnChecked"/>
                        <RadioButton x:Name="IntentSearchModeRadio"
                                     Content="Forgot the name?"
                                     GroupName="DiscoverMode"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="12"
                                     ToolTip="Plain description → what you are probably looking for (character, series, etc.) — no tags"
                                     Checked="DiscoverModeRadio_OnChecked"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="DescriptionHintText"
                           Grid.Row="1"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           LineHeight="16"
                           Margin="0,0,0,6"/>

                <Expander x:Name="ApiHelpExpander"
                          Grid.Row="2"
                          Style="{StaticResource R34Expander}"
                          IsExpanded="False"
                          Header="OpenAI API key help"
                          Margin="0,0,0,8">
                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="17"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0">
                        <Run Text="Describe search uses your key from Account. Browse, downloads, and local files do not."/>
                        <LineBreak/>
                        <Run Text="1. platform.openai.com → API keys → create key"/>
                        <LineBreak/>
                        <Run Text="2. Paste on Account → AI describe search"/>
                    </TextBlock>
                </Expander>

                <!-- Scrollable main body -->
                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="ThemeInputLabel"
                                   Text="Description"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="DescriptionInput"
                                 Style="{StaticResource R34FieldTextBox}"
                                 MinHeight="56"
                                 MaxHeight="96"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10"
                                 KeyDown="DescriptionInput_OnKeyDown"/>

                        <StackPanel x:Name="QuestionPanel"
                                    Visibility="Collapsed">
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,10,0,0"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="QuestionProgressText"
                                               Foreground="{StaticResource R34GreenBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBlock x:Name="QuestionPromptText"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                    <StackPanel x:Name="QuestionOptionsPanel" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="QuestionFreeTextLabel"
                                               Text="Optional details"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <TextBox x:Name="QuestionFreeTextInput"
                                             Style="{StaticResource R34FieldTextBox}"
                                             MinHeight="32"
                                             MaxHeight="64"
                                             Margin="0,0,0,10"
                                             ToolTip="Optional — add details in your own words"/>
                                    <StackPanel x:Name="QuestionActionsPanel"
                                                Orientation="Horizontal">
                                        <Button x:Name="ContinueQuestionnaireButton"
                                                Content="Continue"
                                                Style="{StaticResource PrimaryButton}"
                                                MinWidth="100"
                                                Margin="0,0,8,0"
                                                Click="ContinueQuestionnaireButton_OnClick"/>
                                        <Button x:Name="SkipToTagsButton"
                                                Content="Skip to tags"
                                                Style="{StaticResource SecondaryButton}"
                                                MinWidth="100"
                                                Click="SkipToTagsButton_OnClick"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border x:Name="ResultsPanel"
                                Background="#121212"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                MinHeight="140">
                            <StackPanel>
                                <TextBlock x:Name="InterpretationSummaryText"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"
                                           Visibility="Collapsed"/>

                                <TextBlock x:Name="SearchHitsHeader"
                                           Text="What you might be looking for"
                                           Foreground="{StaticResource R34GreenBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                <StackPanel x:Name="SearchHitsPanel" Margin="0,0,0,10"/>

                                <TextBlock x:Name="PresetsHeader"
                                           Text="Matching search presets"
                                           Foreground="{StaticResource R34GreenBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                <StackPanel x:Name="PresetsPanel" Margin="0,0,0,10"/>

                                <TextBlock x:Name="CombinationsHeader"
                                           Text="Suggested search lines"
                                           Foreground="{StaticResource R34GreenBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                <StackPanel x:Name="CombinationsPanel" Margin="0,0,0,10"/>

                                <TextBlock x:Name="TagsHeader"
                                           Text="Individual tags"
                                           Foreground="{StaticResource R34GreenBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                <StackPanel x:Name="TagsPanel"/>

                                <TextBlock x:Name="EmptyText"
                                           Text="Enter a description and click Suggest tags."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: actions + status + done -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="ThemeActionsPanel"
                                Orientation="Horizontal"
                                Grid.Column="0">
                        <Button x:Name="SuggestButton"
                                Content="Suggest tags"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="110"
                                Click="SuggestButton_OnClick"/>
                    </StackPanel>
                    <StackPanel x:Name="QuestionnaireActionsPanel"
                                Orientation="Horizontal"
                                Grid.Column="0"
                                Visibility="Collapsed">
                        <Button x:Name="StartQuestionnaireButton"
                                Content="Start questionnaire"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="130"
                                Click="StartQuestionnaireButton_OnClick"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="12,0,12,0"/>
                    <Button Grid.Column="2"
                            Content="Done"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="80"
                            Padding="16,6"
                            Click="DoneButton_OnClick"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
