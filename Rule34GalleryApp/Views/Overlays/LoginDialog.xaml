<UserControl x:Class="Rule34GalleryApp.Views.Overlays.LoginDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid Background="#CC000000">
        <Border Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="28"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel>
                <TextBlock Text="Sign in to your account"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>
                <Button x:Name="GoogleSignInButton"
                        Content="Sign in with Google"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Click="GoogleSignInButton_OnClick"/>
                <TextBlock x:Name="GoogleSetupHintText"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>
                <TextBlock Text="— or use email —"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Email" Margin="0,0,0,6" Foreground="{StaticResource MutedBrush}"/>
                <TextBox x:Name="LoginEmailInput" Margin="0,0,0,12"/>
                <TextBlock Text="Password" Margin="0,0,0,6" Foreground="{StaticResource MutedBrush}"/>
                <PasswordBox x:Name="LoginPasswordInput" Margin="0,0,0,12"/>
                <TextBlock x:Name="LoginErrorText"
                           Foreground="#f0a0a0"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>
                <Button Content="Sign in"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Click="LoginSubmitButton_OnClick"/>
                <Button Content="Create account"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Click="SignUpSubmitButton_OnClick"/>
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,10"
                        Click="CancelButton_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
