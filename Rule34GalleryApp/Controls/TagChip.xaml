<UserControl x:Class="Rule34GalleryApp.Controls.TagChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="ChipBorder"
            Padding="8,4"
            CornerRadius="6"
            BorderThickness="1"
            BorderBrush="#444444"
            Cursor="Hand"
            MouseLeftButtonUp="ChipBorder_OnMouseLeftButtonUp">
        <TextBlock x:Name="ChipText" FontSize="12" FontWeight="SemiBold"/>
    </Border>
</UserControl>
