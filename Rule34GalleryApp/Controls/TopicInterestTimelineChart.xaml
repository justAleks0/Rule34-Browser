<UserControl x:Class="Rule34GalleryApp.Controls.TopicInterestTimelineChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="180">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="108"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="LegendPanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,8,8,0"
                    VerticalAlignment="Center"/>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#101010"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True"
                Margin="0,0,0,4"
                SizeChanged="ChartHost_OnSizeChanged">
            <Canvas x:Name="ChartCanvas"
                    Margin="10,10,10,8"/>
        </Border>

        <TextBlock x:Name="TimeStartLabel"
                   Grid.Row="1"
                   Grid.Column="1"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="10"
                   Margin="10,0,0,0"/>
        <TextBlock x:Name="TimeEndLabel"
                   Grid.Row="1"
                   Grid.Column="1"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="10"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"/>

        <TextBlock x:Name="EmptyText"
                   Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="Browse and search more to build an interest timeline."
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="12"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
