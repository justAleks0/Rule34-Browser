<UserControl x:Class="Rule34GalleryApp.Controls.AccountCredentialsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SettingsCategoryHeader}"
                   Text="Rule34 API"
                   Margin="0,0,0,8"/>
        <TextBlock Style="{StaticResource BrowseSectionHint}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
            <Run Text="Used to authenticate with rule34.xxx when searching posts, opening galleries, and downloading files."/>
            <LineBreak/>
            <Run Text="Required for Browse and downloads. Local Library, favorites, and settings work without it." FontWeight="SemiBold"/>
        </TextBlock>
        <Border Style="{StaticResource BrowseSectionCard}">
            <StackPanel>
                <TextBlock Style="{StaticResource SettingsSubHeader}" Text="Quick paste"/>
                <TextBlock Style="{StaticResource BrowseSectionHint}"
                           Text="Paste the green box from rule34.xxx → Account → Options"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="CredentialBlobInput"
                         MinHeight="48"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"
                         TextChanged="CredentialBlobInput_OnTextChanged"/>
                <TextBlock Style="{StaticResource SettingsSubHeader}" Text="Credentials"/>
                <TextBlock Style="{StaticResource MutedText}" Text="User ID" Margin="0,0,0,4"/>
                <TextBox x:Name="UserIdInput"
                         Margin="0,0,0,10"
                         TextChanged="CredentialInput_OnTextChanged"/>
                <TextBlock Style="{StaticResource MutedText}" Text="API key" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ApiKeyInput"
                             Margin="0,0,0,8"
                             PasswordChanged="ApiKeyInput_OnPasswordChanged"
                             LostFocus="Credentials_OnLostFocus"/>
                <Expander Style="{StaticResource R34Expander}"
                          IsExpanded="False"
                          Header="How to get your API key">
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0">
                        <Run Text="1. Log in at rule34.xxx"/>
                        <LineBreak/>
                        <Run Text="2. Open Account → Options"/>
                        <LineBreak/>
                        <Run Text="3. Copy the green credential box (or the User ID and API key fields)"/>
                        <LineBreak/>
                        <Run Text="4. Paste into Quick paste above — User ID and API key fill in automatically"/>
                    </TextBlock>
                </Expander>
            </StackPanel>
        </Border>

        <TextBlock Style="{StaticResource SettingsCategoryHeader}" Text="AI describe search"/>
        <TextBlock Style="{StaticResource BrowseSectionHint}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
            <Run Text="Used for Describe search — turns a plain-language scene into tag and preset suggestions via OpenAI."/>
            <LineBreak/>
            <Run Text="Optional. Everything else (Browse, library, downloads, local files) works without it." FontWeight="SemiBold"/>
        </TextBlock>
        <Border Style="{StaticResource BrowseSectionCard}">
            <StackPanel>
                <TextBlock Style="{StaticResource MutedText}" Text="OpenAI API key" Margin="0,0,0,4"/>
                <PasswordBox x:Name="OpenAiApiKeyInput"
                             Margin="0,0,0,10"
                             PasswordChanged="OpenAiApiKeyInput_OnPasswordChanged"
                             LostFocus="OpenAiSettings_OnLostFocus"/>
                <TextBlock Style="{StaticResource MutedText}" Text="Model" Margin="0,0,0,4"/>
                <TextBox x:Name="OpenAiModelInput"
                         Style="{StaticResource R34FieldTextBox}"
                         Margin="0,0,0,10"
                         ToolTip="Default: gpt-4o-mini"
                         TextChanged="OpenAiModelInput_OnTextChanged"
                         LostFocus="OpenAiSettings_OnLostFocus"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="Use OpenAI for describe"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <CheckBox x:Name="UseOpenAiDescribeCheckBox"
                              Style="{StaticResource ToggleSwitchStyle}"
                              Checked="UseOpenAiDescribe_OnChanged"
                              Unchecked="UseOpenAiDescribe_OnChanged"/>
                </StackPanel>
                <Expander Style="{StaticResource R34Expander}"
                          IsExpanded="False"
                          Header="How to get an OpenAI API key"
                          Margin="0,10,0,0">
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0">
                        <Run Text="1. Create an account at platform.openai.com"/>
                        <LineBreak/>
                        <Run Text="2. Open API keys in your account settings"/>
                        <LineBreak/>
                        <Run Text="3. Create a new secret key and copy it"/>
                        <LineBreak/>
                        <Run Text="4. Paste it above — it stays on this device (and syncs if you sign in)"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Hyperlink NavigateUri="https://platform.openai.com/api-keys" RequestNavigate="OpenAiHelpLink_OnRequestNavigate">
                            Open OpenAI API keys page
                        </Hyperlink>
                    </TextBlock>
                </Expander>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
