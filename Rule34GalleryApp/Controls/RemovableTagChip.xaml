<UserControl x:Class="Rule34GalleryApp.Controls.RemovableTagChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,6,6">
    <Border x:Name="ChipBorder"
            Padding="8,4"
            CornerRadius="6"
            BorderThickness="1"
            BorderBrush="#444444">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="ChipText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <Button x:Name="RemoveButton"
                    Content="×"
                    Width="18"
                    Height="18"
                    Padding="0"
                    FontSize="12"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Style="{StaticResource SecondaryButton}"
                    Click="RemoveButton_OnClick"
                    ToolTip="Remove tag"/>
        </StackPanel>
    </Border>
</UserControl>
