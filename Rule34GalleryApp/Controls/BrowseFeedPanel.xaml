<UserControl x:Class="Rule34GalleryApp.Controls.BrowseFeedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A"
             PreviewMouseWheel="BrowseFeedPanel_OnPreviewMouseWheel">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ClipToBounds="True">
            <Image x:Name="FeedImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
            <MediaElement x:Name="FeedMedia"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="Collapsed"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          ScrubbingEnabled="True"/>
            <TextBlock x:Name="EmptyText"
                       Text="Search to load posts"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <Border Grid.Row="1"
                Background="#99000000"
                Padding="12,8">
            <StackPanel>
                <TextBlock x:Name="FeedStatusText"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button x:Name="FeedFavoriteButton"
                            Content="Favorite"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="88"
                            Margin="0,0,8,0"
                            Click="FeedFavoriteButton_OnClick"/>
                    <Button x:Name="FeedWatchLaterButton"
                            Content="Watch later"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="100"
                            Click="FeedWatchLaterButton_OnClick"/>
                </StackPanel>
                <TextBlock x:Name="FeedAudioDeviceText"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="10"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
