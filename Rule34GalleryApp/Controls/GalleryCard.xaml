<UserControl x:Class="Rule34GalleryApp.Controls.GalleryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Rule34GalleryApp"
             Width="232"
             Height="300"
             Cursor="Hand">
    <UserControl.Resources>
        <Storyboard x:Key="HoverIn">
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.03" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.03" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="HoverOut">
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </UserControl.Resources>
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="CardScale" CenterX="116" CenterY="150"/>
    </UserControl.RenderTransform>
    <Border x:Name="CardBorder"
            Background="{StaticResource SurfaceRaisedBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CardCornerRadius}"
            MouseEnter="Card_OnMouseEnter"
            MouseLeave="Card_OnMouseLeave">
        <Grid>
            <StackPanel>
                <Border Height="220" Margin="6,6,6,0" CornerRadius="8" ClipToBounds="True" Background="#0A0A0A">
                    <Grid>
                        <Image Stretch="Uniform"
                               local:ImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                               local:ImageLoader.DecodePixelWidth="260"/>
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="8"
                                Padding="6,3"
                                CornerRadius="4"
                                Background="#CC000000">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowMediaBadge}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding MediaBadge}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>
                <Grid Margin="10,8,10,4">
                    <StackPanel>
                        <TextBlock Text="{Binding GalleryTitle}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,48,0"/>
                        <TextBlock Text="{Binding GallerySubtitle}"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,48,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasGallerySubtitle}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <Border HorizontalAlignment="Right"
                            Padding="6,2"
                            CornerRadius="4"
                            Background="{Binding Rating, Converter={StaticResource RatingBrushConverter}}">
                        <TextBlock Text="{Binding Rating}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#111111"/>
                    </Border>
                </Grid>
                <StackPanel x:Name="LocalActionPanel"
                            Orientation="Horizontal"
                            Margin="10,0,10,4"
                            Opacity="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowLocalThumbEdit}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="Thumb"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,4"
                            Tag="{Binding}"
                            ToolTip="Pick thumbnail frame"
                            Click="ThumbEdit_OnClick"/>
                </StackPanel>
                <StackPanel x:Name="ActionPanel"
                            Orientation="Horizontal"
                            Margin="10,0,10,10"
                            Opacity="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowCloudActions}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="{Binding FavoriteGlyph}"
                            Width="36"
                            Margin="0,0,6,0"
                            Padding="0"
                            FontSize="16"
                            Tag="{Binding}"
                            ToolTip="Toggle favorite"
                            Click="Favorite_OnClick"/>
                    <Button Content="{Binding WatchLaterGlyph}"
                            Width="36"
                            Margin="0,0,6,0"
                            Padding="0"
                            FontSize="14"
                            Tag="{Binding}"
                            ToolTip="Watch Later"
                            Click="WatchLater_OnClick"/>
                    <Button Content="↓"
                            Width="36"
                            Margin="0,0,6,0"
                            Padding="0"
                            FontSize="14"
                            Tag="{Binding}"
                            ToolTip="Download to local library"
                            Click="Download_OnClick"/>
                    <Button Content="+ List"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,4"
                            Tag="{Binding}"
                            ToolTip="Add to list"
                            Click="AddToList_OnClick"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
